{
  "name": "fiber-scope",
  "version": "0.1.0",
  "private": true,
  "description": "Visual React performance heatmap and render debugging toolkit",
  "type": "module",
  "workspaces": [
    "packages/fiberscope",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "dev": "npm run dev --workspace @fiberscope/react-demo",
    "lint": "eslint .",
    "test": "vitest run",
    "format": "prettier --write .",
    "typecheck": "tsc -p tsconfig.base.json --noEmit"
  },
  "keywords": [
    "react",
    "performance",
    "profiler",
    "devtools",
    "heatmap"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.13"
  }
}
