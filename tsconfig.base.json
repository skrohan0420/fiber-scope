{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@rohan0420/fiberscope-core": ["packages/core/src/index.ts"],
      "@rohan0420/fiberscope-react": ["packages/react/src/index.ts"],
      "@rohan0420/fiberscope-overlay": ["packages/overlay/src/index.ts"]
    }
  },
  "include": ["packages/*/src", "examples/*/src", "*.config.ts", "*.config.js"]
}
